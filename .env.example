# Sample configuration for the Steam sale notifier.
# Copy this file to `.env` and fill in your own values:
#
#   cp .env.example .env
#
# The real `.env` is gitignored so secrets never land in git. Variables set in
# the actual environment (e.g. `docker run -e ...`) take precedence over .env.

# Required: channel-scoped Slack incoming webhook URL.
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXXX/YYYY/ZZZZ"

# Optional: a title counts as "on sale" only at/above this discount percent.
DISCOUNT_THRESHOLD=25

# Optional: storefront region -> currency (DE = EUR) and title-name language.
STEAM_CC=DE
STEAM_LANG=english

# Optional: IsThereAnyDeal API key to tag sales with all-time-low context.
# Leave blank to disable the enrichment. Get one at https://isthereanydeal.com/apps/
ITAD_API_KEY=
